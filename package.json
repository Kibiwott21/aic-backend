{
  "name": "aic-kapsowar-hms-backend",
  "version": "10.1.0",
  "description": "AIC Kapsowar Hospital Management System Backend",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "setup-db": "node -e \"import('./config/database.js').then(m=>m.testConnection()).then(()=>process.exit(0))\"",
    "migrate": "psql $DATABASE_URL -f db/schema_v10.sql",
    "lint": "node --check server.js routes/index.js controllers/authController.js middleware/auth.js middleware/wifiControl.js services/emailService.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
