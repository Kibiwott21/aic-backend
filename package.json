{
  "name": "aic-kapsowar-hms-backend",
  "version": "10.1.0",
  "description": "AIC Kapsowar Hospital Management System Backend",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "setup-db": "node -e \"import('./config/database.js').then(m=>m.testConnection()).then(()=>process.exit(0))\"",
    "migrate": "psql $DATABASE_URL -f db/schema_v10.sql"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.7",
    "pg": "^8.11.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
