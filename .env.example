# ─────────────────────────────────────────────────────────────────
# AIC Kapsowar HMS v10 — Environment Template
# Copy this to .env and fill in your actual values
# NEVER commit .env to version control!
# ─────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=5000

# ── URLS ──────────────────────────────────────────────────────────
LOCAL_FRONTEND_URL=http://localhost:5000
PROD_FRONTEND_URL=https://aickapsowarhospital.vercel.app
LOCAL_BACKEND_URL=http://localhost:5000
PROD_BACKEND_URL=https://aic-backend-bfdw.onrender.com

# ── LOCAL PostgreSQL ──────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=your_local_postgres_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aic_hms

# ── RENDER PostgreSQL ─────────────────────────────────────────────
# Get these values from Render dashboard → Database → Connection String
PROD_DB_USER=postgres_username
PROD_DB_PASSWORD=your_render_db_password_here
PROD_DB_HOST=dpg-xxxxx.region-postgres.render.com
PROD_DB_PORT=5432
PROD_DB_NAME=aic_hms
PROD_DB_INTERNAL_URL=postgresql://user:password@internal-host/aic_hms
PROD_DB_EXTERNAL_URL=postgresql://user:password@external-host:5432/aic_hms

# ── JWT ───────────────────────────────────────────────────────────
# For production: use a 256-bit hex string (generated securely)
# For development: any string works, but use something strong
JWT_SECRET=your-secure-jwt-secret-256-bits-here
JWT_EXPIRES_IN=12h

# ── EMAIL ─────────────────────────────────────────────────────────
# Using Gmail SMTP with App Password (not regular password)
# See: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password-here
EMAIL_FROM=AIC Kapsowar Hospital <your-email@gmail.com>
ADMIN_EMAIL=admin@yourdomain.com

# ── HOSPITAL DETAILS ──────────────────────────────────────────────
HOSPITAL_NAME=AIC Kapsowar Hospital
HOSPITAL_PHONE=+254757632293
HOSPITAL_EMAIL=hospital@example.com
CURRENCY=KES

# ── WIFI CONTROL ──────────────────────────────────────────────────
# Optional: Set to 'true' to enable WiFi access control
WIFI_CONTROL_ENABLED=false
WIFI_CONTROL_URL=http://router-ip:port

# ── LOGGING ───────────────────────────────────────────────────────
# Options: 'debug', 'info', 'warn', 'error'
LOG_LEVEL=info

# ── CORS ORIGINS (comma-separated) ────────────────────────────────
# Already configured in server.js, but can override here if needed
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,https://yourdomain.com
